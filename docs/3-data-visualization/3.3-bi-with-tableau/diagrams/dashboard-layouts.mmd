flowchart LR
    subgraph P1["Pattern 1 — KPI Strip + Detail"]
        direction TB
        subgraph KPI["Top row: KPI scorecards"]
            direction LR
            K1["KPI 1<br/>Total Sales"]
            K2["KPI 2<br/>Profit Margin"]
            K3["KPI 3<br/>Orders Count"]
            K4["KPI 4<br/>Avg Discount"]
        end
        DC["Detail chart<br/>Sales & Profit over time"]
        KPI --> DC
    end

    subgraph P2["Pattern 2 — Hero + Supporting"]
        direction TB
        subgraph ROW2["Side by side"]
            direction LR
            MC["Main chart<br/>60% width<br/>Map / trend"]
            subgraph SUP["Supporting charts"]
                direction TB
                S1["Top product<br/>categories"]
                S2["Regional<br/>breakdown"]
                S3["Month-on-month<br/>growth"]
            end
        end
        MC --- SUP
    end

    subgraph P3["Pattern 3 — Grid"]
        direction TB
        subgraph ROW_A["Row A"]
            direction LR
            G1["Sales<br/>by category"]
            G2["Profit<br/>by region"]
        end
        subgraph ROW_B["Row B"]
            direction LR
            G3["Orders<br/>over time"]
            G4["Discount<br/>vs profit"]
        end
        ROW_A --> ROW_B
    end
