flowchart TD
    subgraph WORKSPACE["Tableau Workspace"]
        subgraph DATA_PANE["Data Pane (left)"]
            DIM["Dimensions<br/>(blue pills)<br/>Categories — Region, Category, Date"]
            MEA["Measures<br/>(green pills)<br/>Numbers — Sales, Profit, Quantity"]
        end
        subgraph SHELVES["Shelves (top)"]
            COL["Columns shelf → X-axis"]
            ROW["Rows shelf → Y-axis"]
            FLT["Filters shelf<br/>Limit which data appears"]
            PAG["Pages shelf<br/>Animate / page through data"]
        end
        subgraph MARKS["Marks Card (left-center)"]
            CLR["Color"]
            SIZ["Size"]
            LBL["Label"]
            DET["Detail"]
            TTP["Tooltip"]
        end
        subgraph CANVAS["Canvas / View (center)"]
            CHART["Chart renders here\nbased on shelf & marks settings"]
        end
    end

    DATA_PANE -->|"drag here"| SHELVES
    DATA_PANE -->|"drag here"| MARKS
    SHELVES --> CANVAS
    MARKS --> CANVAS
