flowchart LR
    DS["Data Source<br/>(Database / CSV / Cloud)"]

    DS -->|"Live Connection"| LIVE_DESC["Every interaction<br/>queries the source directly"]
    DS -->|"Extract (.hyper)"| EXT_DESC["Snapshot of data<br/>stored locally"]

    LIVE_DESC --> LIVE_PROS["Pros<br/>+ Always up-to-date"]
    LIVE_DESC --> LIVE_CONS["Cons<br/>- Slower<br/>- Requires network access"]
    LIVE_PROS --> LIVE_BEST["Best for<br/>Small datasets<br/>Real-time needs"]
    LIVE_CONS --> LIVE_BEST

    EXT_DESC --> EXT_PROS["Pros<br/>+ Fast<br/>+ Works offline<br/>+ Can be scheduled to refresh"]
    EXT_DESC --> EXT_CONS["Cons<br/>- Data may be stale<br/>between refreshes"]
    EXT_PROS --> EXT_BEST["Best for<br/>Large datasets<br/>Offline work<br/>Sharing .twbx files"]
    EXT_CONS --> EXT_BEST

    LIVE_BEST --> WB["Tableau Workbook"]
    EXT_BEST --> WB

    DECIDE{"Which to use?"}
    DECIDE -->|"Need real-time data?"| REAL_Q{"Yes / No"}
    REAL_Q -->|"Yes"| LIVE_BEST
    REAL_Q -->|"No"| EXT_BEST
