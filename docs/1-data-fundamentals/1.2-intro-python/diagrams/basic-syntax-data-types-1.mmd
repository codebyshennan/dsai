flowchart TD
    PY[Python types] --> NUM[Numeric]
    PY --> TXT[Text]
    PY --> BOOL[Boolean]
    PY --> MISS[Missing / special]
    NUM --> INT["int 1, 1000"]
    NUM --> FLT["float 3.14, 23.5"]
    NUM --> NINT["`numpy int32/int64 np.int32(1)`"]
    NUM --> NFLT["`numpy float64 np.float64(1.1)`"]
    TXT --> STR["`str 'Hello'`"]
    BOOL --> B["bool True / False"]
    MISS --> NONE["`None (Python missing)`"]
    MISS --> NAN["`np.nan (numeric missing)`"]
    MISS --> NATD["`pd.NaT (datetime missing)`"]
