flowchart TD
    subgraph SEARCH["Search strategies"]
        GS["Grid Search Exhaustive: all combinations Safe, slow, scales poorly"]
        RS["Random Search Sample n random combos Faster, often as good"]
        BO["`Bayesian Optimisation (Optuna / HyperOpt) Learns from past trials Best for expensive models`"]
    end
    subgraph SAFE["Leakage-free workflow"]
        TRN["Train set"] --> CV["`Inner CV (GridSearchCV / RandomizedSearchCV) Finds best hyperparams`"]
        CV --> REFIT["Refit on full train set with best params"]
        REFIT --> TEST["`Evaluate on held-out test set (touch ONCE)`"]
    end
    GS & RS & BO --> CV
