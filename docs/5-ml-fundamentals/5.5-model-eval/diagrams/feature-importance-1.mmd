flowchart LR
    subgraph TREE["`Tree / MDI importance  (fast)`"]
        T1["Sum mean impurity decrease across all trees and splits"]
        T1 --> T2["Built-in: rf.feature_importances_ Fast — no extra fit"]
        T2 --> T3["Caveat: biased toward high-cardinality features Correlated features split importance"]
    end
    subgraph PERM["`Permutation importance  (reliable)`"]
        P1["1. Evaluate baseline score"]
        P1 --> P2["2. Shuffle one feature column"]
        P2 --> P3["3. Score drop = importance"]
        P3 --> P4["Repeat for each feature n_repeats times"]
        P4 --> P5["Model-agnostic Works on any fitted estimator"]
    end
    subgraph SHAP["`SHAP values  (most interpretable)`"]
        S1["Shapley values from game theory Each feature gets a fair credit share"]
        S1 --> S2["`Local (per prediction) + Global (aggregated) Best for stakeholder explanations`"]
    end
    CHOOSE{"Which to use?"}
    CHOOSE -->|"Quick baseline"| TREE
    CHOOSE -->|"Correlated features or need reliability"| PERM
    CHOOSE -->|"Production / regulatory explanation"| SHAP
