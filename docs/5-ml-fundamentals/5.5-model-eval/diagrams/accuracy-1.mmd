flowchart LR
    subgraph CONF["Confusion matrix"]
        TP["`TP (correct positive)`"]
        TN["`TN (correct negative)`"]
        FP["`FP (false alarm)`"]
        FN["`FN (missed positive)`"]
    end
    ACC["`Accuracy = (TP + TN) / (TP + TN + FP + FN)`"]
    CONF --> ACC
    subgraph WHEN["When accuracy misleads"]
        IMB["Imbalanced classes 99% negative → predict all negative → 99% accuracy, zero recall!"]
    end
    ACC --> WHEN
    WHEN --> USE["Use Precision, Recall, F1, or PR-AUC instead"]
