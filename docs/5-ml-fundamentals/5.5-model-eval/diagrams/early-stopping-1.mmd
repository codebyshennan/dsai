flowchart LR
    subgraph TRAIN_LOOP["Training loop"]
        E1["Epoch 1"] --> E2["Epoch 2"] --> E3["..."] --> EN["Epoch N"]
    end
    subgraph CHECK["After each epoch"]
        VAL["Measure validation loss"]
        BETTER{Better than best so far?}
        SAVE["Save checkpoint + reset patience counter"]
        WAIT["Increment patience counter"]
        STOP{Counter ≥ patience limit?}
        HALT["Stop training Restore best checkpoint"]
    end
    EN --> VAL --> BETTER
    BETTER -->|Yes| SAVE --> E1
    BETTER -->|No| WAIT --> STOP
    STOP -->|No| E1
    STOP -->|Yes| HALT
