flowchart LR
    subgraph ROC["`ROC Curve  (vary threshold 0 → 1)`"]
        AX["`x-axis: FPR = FP / (FP + TN) = false alarm rate`"]
        AY["`y-axis: TPR = TP / (TP + FN) = sensitivity / recall`"]
        LOW["`Low threshold (predict + for almost all) High TPR — but high FPR too`"]
        HIGH["`High threshold (predict + rarely) Low FPR — but misses many +`"]
    end
    subgraph AUC["AUC interpretation"]
        A1["AUC = 1.0 Perfect ranking"]
        A2["`AUC ≈ 0.5 Random classifier (diagonal line)`"]
        A3["`AUC < 0.5 Worse than random (flip predictions)`"]
        A4["AUC ≈ 0.7–0.8 Typically acceptable for tabular models"]
    end
    ROC --> AUC
