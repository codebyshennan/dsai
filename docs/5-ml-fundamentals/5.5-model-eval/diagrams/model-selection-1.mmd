flowchart TD
    subgraph CRITERIA["Selection criteria"]
        PERF["`Predictive performance (CV score on train set)`"]
        INTERP["`Interpretability (Logistic < RF < NN)`"]
        SPEED["`Inference speed (Linear: µs, NN: ms)`"]
        DATA["`Data size (small → simpler model large → complex OK)`"]
    end
    subgraph WORKFLOW["Safe model comparison workflow"]
        SPLIT["`Train / Val / Test split (or nested CV)`"]
        SPLIT --> CANDIDATES["Evaluate candidate model families on Val"]
        CANDIDATES --> BEST["Select best family + tune hyperparams with inner CV"]
        BEST --> FINAL["`Evaluate once on held-out Test set (report this number)`"]
    end
    subgraph PITFALLS["Common mistakes"]
        M1["Peeking at test set during model selection"]
        M2["Not baselining against a naive predictor"]
        M3["Optimizing val set score then reporting it as test score"]
    end
    CRITERIA --> WORKFLOW
    WORKFLOW -.-> PITFALLS
