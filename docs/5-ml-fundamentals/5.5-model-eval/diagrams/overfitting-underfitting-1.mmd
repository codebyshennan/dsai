flowchart LR
    subgraph UNDERFIT["`Underfitting (high bias)`"]
        U1["Model too simple"] --> U2["Low train accuracy Low test accuracy"]
        U2 --> U3["`Gap: small (both bad)`"]
    end
    subgraph GOODFIT["Good fit"]
        G1["Right complexity"] --> G2["High train accuracy High test accuracy"]
        G2 --> G3["`Gap: small (both good)`"]
    end
    subgraph OVERFIT["`Overfitting (high variance)`"]
        O1["Model too complex"] --> O2["Very high train accuracy Low test accuracy"]
        O2 --> O3["`Gap: large (memorised noise)`"]
    end

    FIX1["Fix underfitting: more features, larger model, less regularization"] -.-> UNDERFIT
    FIX2["Fix overfitting: more data, dropout, more regularization"] -.-> OVERFIT
