#!/bin/bash
#
# Pre-commit hook to validate Jekyll/GitHub Pages compatibility
# This prevents commits containing unsupported Liquid tags
#

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running Jekyll validation...${NC}"

# Get the root directory of the repository
REPO_ROOT=$(git rev-parse --show-toplevel)
DOCS_DIR="$REPO_ROOT/docs"

# Get list of staged markdown files in docs directory
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^docs/.*\.md$" || true)

if [ -z "$STAGED_MD_FILES" ]; then
    echo -e "${GREEN}✓ No markdown files to validate${NC}"
    exit 0
fi

echo "Validating $(echo "$STAGED_MD_FILES" | wc -l | tr -d ' ') markdown file(s)..."

# Run validation on staged files
cd "$REPO_ROOT"
python3 "$DOCS_DIR/validate_jekyll.py" $STAGED_MD_FILES

VALIDATION_RESULT=$?

if [ $VALIDATION_RESULT -ne 0 ]; then
    echo -e "${RED}✗ Commit rejected - Jekyll validation failed${NC}"
    echo ""
    echo "To fix these issues:"
    echo "  1. Run: python3 docs/fix_liquid_tags.py"
    echo "  2. Review the changes"
    echo "  3. Stage the fixed files: git add docs/"
    echo "  4. Try committing again"
    echo ""
    echo "To skip this check (not recommended):"
    echo "  git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}✓ Jekyll validation passed${NC}"
exit 0
